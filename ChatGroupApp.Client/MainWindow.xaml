<Window x:Class="ChatGroupApp.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ChatGroupApp"
        Height="720"
        MinHeight="600"
        Width="1000"
        MinWidth="840"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/AppIcon.ico"
        Closing="Window_Closing">
    <Window.Resources>
        <LinearGradientBrush x:Key="PageBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF1F8" Offset="0" />
            <GradientStop Color="#EAF7FF" Offset="0.52" />
            <GradientStop Color="#F5EEFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CandyBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF8FC7" Offset="0" />
            <GradientStop Color="#8DD7FF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SendBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF7AB6" Offset="0" />
            <GradientStop Color="#B48CFF" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="InkBrush" Color="#2B2440" />
        <SolidColorBrush x:Key="MutedBrush" Color="#7F7895" />
        <SolidColorBrush x:Key="CardBrush" Color="#FAFDFF" />

        <Style x:Key="CuteButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource SendBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="21"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16"
                                                  ShadowDepth="5"
                                                  Opacity="0.24"
                                                  Color="#D46FB1" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftButton" BasedOn="{StaticResource CuteButton}" TargetType="Button">
            <Setter Property="Foreground" Value="#B23B72" />
            <Setter Property="Background" Value="#FFE2F0" />
        </Style>

        <Style x:Key="CuteTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderBrush" Value="#F2C9DE" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="#FF66A8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="21">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmojiButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FFF0F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI Emoji" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE0F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmojiTabStyle" BasedOn="{StaticResource EmojiButtonStyle}" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="#F2F7FF" />
            <Setter Property="FontSize" Value="19" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBrush}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,14"
                Padding="22"
                Background="{StaticResource CardBrush}"
                CornerRadius="26">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="8"
                                  Opacity="0.18"
                                  Color="#E690C4" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="56"
                                Height="56"
                                Background="{StaticResource CandyBrush}"
                                CornerRadius="20"
                                Margin="0,0,14,0">
                            <TextBlock Text="&#x1F4AC;"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="30"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ChatGroupApp"
                                       FontSize="28"
                                       FontWeight="Black"
                                       Foreground="{StaticResource InkBrush}" />
                            <TextBlock x:Name="StatusTextBlock"
                                       Text="Sẵn sàng kết nối nè!"
                                       FontSize="14"
                                       Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#FFF0F7"
                            CornerRadius="18"
                            Padding="14,9"
                            VerticalAlignment="Center">
                        <TextBlock Text="Lab 01 | GroupChat"
                                   Foreground="#C24A86"
                                   FontWeight="Bold" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ServerIpTextBox"
                             Grid.Column="0"
                             Style="{StaticResource CuteTextBox}"
                             Margin="0,0,10,0"
                             Text="IP"
                             ToolTip="IP Server" />

                    <TextBox x:Name="PortTextBox"
                             Grid.Column="1"
                             Style="{StaticResource CuteTextBox}"
                             Margin="0,0,10,0"
                             Text="5000"
                             ToolTip="Port" />

                    <TextBox x:Name="UserNameTextBox"
                             Grid.Column="2"
                             Style="{StaticResource CuteTextBox}"
                             Margin="0,0,10,0"
                             Text="Student"
                             ToolTip="Tên của bạn" />

                    <Button x:Name="ConnectButton"
                            Grid.Column="3"
                            Style="{StaticResource CuteButton}"
                            Width="122"
                            Margin="0,0,10,0"
                            Content="Kết nối"
                            Click="ConnectButton_Click" />

                    <Button x:Name="DisconnectButton"
                            Grid.Column="4"
                            Style="{StaticResource SoftButton}"
                            Width="96"
                            Content="Ngắt"
                            IsEnabled="False"
                            Click="DisconnectButton_Click" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="20,0,20,14"
                Background="#FDFEFF"
                CornerRadius="26">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="8"
                                  Opacity="0.14"
                                  Color="#9AD4F4" />
            </Border.Effect>
            <Grid>
                <ListBox x:Name="MessagesListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Segoe UI Emoji, Segoe UI"
                         FontSize="15"
                         Padding="22"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,6" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="{Binding Alignment}" MaxWidth="620">
                                <Border Padding="16,12"
                                        Background="{Binding Background}"
                                        CornerRadius="{Binding CornerRadius}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"
                                                          ShadowDepth="3"
                                                          Opacity="0.12" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Sender}"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding SenderForeground}"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="15"
                                                   Foreground="{Binding Foreground}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="23" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="EmptyChatHint"
                        Background="#F8F1FF"
                        CornerRadius="24"
                        Padding="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="&#x1F338;"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="58"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Bắt đầu chat nào!"
                                   FontSize="24"
                                   FontWeight="Black"
                                   Foreground="{StaticResource InkBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="Kết nối server rồi gửi tin nhắn đầu tiên."
                                   FontSize="14"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="20,0,20,20"
                Padding="14"
                Background="{StaticResource CardBrush}"
                CornerRadius="26">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  ShadowDepth="7"
                                  Opacity="0.16"
                                  Color="#E690C4" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="EmojiButton"
                        Grid.Column="0"
                        Style="{StaticResource EmojiButtonStyle}"
                        Content="&#x1F60A;"
                        ToolTip="Mở emoji"
                        Click="EmojiButton_Click"
                        Margin="0,0,10,0" />

                <TextBox x:Name="MessageTextBox"
                         Grid.Column="1"
                         Style="{StaticResource CuteTextBox}"
                         IsEnabled="False"
                         KeyDown="MessageTextBox_KeyDown"
                         Margin="0,0,10,0" />

                <Button x:Name="SendButton"
                        Grid.Column="2"
                        Style="{StaticResource CuteButton}"
                        Width="104"
                        Content="Gửi"
                        IsEnabled="False"
                        Click="SendButton_Click" />
            </Grid>
        </Border>

        <Popup x:Name="EmojiPopup"
               PlacementTarget="{Binding ElementName=EmojiButton}"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Width="430"
                    MaxHeight="320"
                    Margin="0,0,0,12"
                    Background="#FFFFFF"
                    BorderBrush="#FFD1E7"
                    BorderThickness="2"
                    CornerRadius="24"
                    Padding="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="8"
                                      Opacity="0.22"
                                      Color="#E690C4" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Chọn emoji"
                               FontSize="18"
                               FontWeight="Black"
                               Foreground="{StaticResource InkBrush}"
                               Margin="4,0,0,14" />

                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="190"
                                  VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="EmojiWrapPanel" />
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0">
                        <Button Style="{StaticResource EmojiTabStyle}"
                                Click="EmojiTab_Click"
                                Tag="Smile"
                                Content="&#x1F600;"
                                ToolTip="Mặt cười" />
                        <Button Style="{StaticResource EmojiTabStyle}"
                                Click="EmojiTab_Click"
                                Tag="Love"
                                Content="&#x2764;"
                                ToolTip="Cảm xúc" />
                        <Button Style="{StaticResource EmojiTabStyle}"
                                Click="EmojiTab_Click"
                                Tag="Hand"
                                Content="&#x1F44D;"
                                ToolTip="Cử chỉ" />
                        <Button Style="{StaticResource EmojiTabStyle}"
                                Click="EmojiTab_Click"
                                Tag="Fun"
                                Content="&#x1F389;"
                                ToolTip="Vui vẻ" />
                        <Button Style="{StaticResource EmojiTabStyle}"
                                Click="EmojiTab_Click"
                                Tag="Food"
                                Content="&#x1F37F;"
                                ToolTip="Đồ ăn" />
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
